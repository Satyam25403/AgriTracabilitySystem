
#  NOTE: All React env vars MUST start with REACT_APP_

# This is the base URL for backend, Axios uses for all /api/... calls
# LOCAL DEV:  Leave blank — the proxy in package.json handles routing to :5000
# PRODUCTION: Render backend URL
# Example: https://agritrace-server.onrender.com/api
REACT_APP_API_URL=

# This is the URL Socket.IO connects to for real-time events
# LOCAL DEV:  Leave blank or set to http://localhost:5000
# PRODUCTION: Render backend URL (no /api at the end)
# Example: https://agritrace-server.onrender.com
REACT_APP_SERVER_URL=