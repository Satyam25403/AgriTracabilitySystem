PORT=5000
NODE_ENV=development

# MongoDB connection string for development (replace with your own)
MONGO_URI=<mongodbatlasstring>/agritrace

JWT_SECRET=agritrace_change_this_to_something_long_and_random_123456
JWT_EXPIRES_IN=7d

# Use Gmail with an App Password (NOT your real Gmail password)
# Steps to get App Password:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification → App passwords
#   3. Generate one for "Mail" and paste below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=AgriTrace Alerts <your_gmail@gmail.com>


# Change to your deployed frontend Vercel URL when you deploy
CLIENT_URL=http://localhost:3000